@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var isAuthenticated = User?.Identity?.IsAuthenticated ?? false;
    var displayName = User?.Identity?.Name;
    if (string.IsNullOrEmpty(displayName))
        displayName = "Guest";
    var isAdmin = isAuthenticated && (User?.IsInRole("Admin") ?? false);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Clinic Management System</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Clinic_App.styles.css" asp-append-version="true" />
    <!-- Early theme script to prevent flicker -->
    <script>
        (function() {
            const theme = localStorage.getItem("clinic-theme") || "light";
            document.documentElement.setAttribute("data-theme", theme);
        })();
    </script>
</head>
<body>
    <div class="app-shell">
        <!-- Mobile Sidebar -->
        <div class="offcanvas offcanvas-start app-sidebar-mobile" tabindex="-1" id="mobileSidebar" aria-labelledby="mobileSidebarLabel">
            <div class="offcanvas-header">
                <h5 class="offcanvas-title" id="mobileSidebarLabel">
                    <i class="bi bi-hospital me-2"></i>Clinic Management
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
            </div>
            <div class="offcanvas-body">
                <nav class="nav flex-column gap-1">
                    @if (isAuthenticated && isAdmin)
                    {
                        <a class="nav-link @(currentController == "Dashboard" ? "active" : string.Empty)" asp-controller="Dashboard" asp-action="Index" data-bs-dismiss="offcanvas">
                            <i class="bi bi-grid-1x2-fill"></i>
                            <span>Dashboard</span>
                        </a>
                        <a class="nav-link @(currentController == "Doctors" ? "active" : string.Empty)" asp-controller="Doctors" asp-action="Index" data-bs-dismiss="offcanvas">
                            <i class="bi bi-heart-pulse"></i>
                            <span>Doctors</span>
                        </a>
                        <a class="nav-link @(currentController == "DoctorAvailabilities" ? "active" : string.Empty)" asp-controller="DoctorAvailabilities" asp-action="Index" data-bs-dismiss="offcanvas">
                            <i class="bi bi-calendar2-week"></i>
                            <span>Doctor Availability</span>
                        </a>
                        <a class="nav-link @(currentController == "Patients" ? "active" : string.Empty)" asp-controller="Patients" asp-action="Index" data-bs-dismiss="offcanvas">
                            <i class="bi bi-people"></i>
                            <span>Patients</span>
                        </a>
                        <a class="nav-link @(currentController == "Appointments" ? "active" : string.Empty)" asp-controller="Appointments" asp-action="Index" data-bs-dismiss="offcanvas">
                            <i class="bi bi-calendar-check"></i>
                            <span>Appointments</span>
                        </a>
                    }
                    else if (isAuthenticated)
                    {
                        <a class="nav-link @(currentController == "Profile" ? "active" : string.Empty)" asp-controller="Profile" asp-action="MyProfile" data-bs-dismiss="offcanvas">
                            <i class="bi bi-person-vcard"></i>
                            <span>My Profile</span>
                        </a>
                        <a class="nav-link @(currentController == "Appointments" && ViewContext.RouteData.Values["action"]?.ToString() == "Create" ? "active" : string.Empty)" asp-controller="Appointments" asp-action="Create" data-bs-dismiss="offcanvas">
                            <i class="bi bi-calendar-plus"></i>
                            <span>Book Appointment</span>
                        </a>
                        <a class="nav-link @(currentController == "Appointments" && ViewContext.RouteData.Values["action"]?.ToString() != "Create" ? "active" : string.Empty)" asp-controller="Appointments" asp-action="Index" data-bs-dismiss="offcanvas">
                            <i class="bi bi-calendar-check"></i>
                            <span>My Appointments</span>
                        </a>
                    }
                </nav>
            </div>
        </div>

        <!-- Desktop Sidebar -->
        @if (isAuthenticated)
        {
            <aside class="app-sidebar d-none d-lg-flex flex-column">
                <div class="sidebar-brand">
                    <div class="brand-icon">
                        <i class="bi bi-hospital"></i>
                    </div>
                    <div>
                        <span class="brand-title">Clinic</span>
                        <small class="brand-subtitle">Management System</small>
                    </div>
                </div>
                <nav class="nav flex-column gap-1">
                    @if (isAdmin)
                    {
                        <a class="nav-link @(currentController == "Dashboard" ? "active" : string.Empty)" asp-controller="Dashboard" asp-action="Index">
                            <i class="bi bi-grid-1x2-fill"></i>
                            <span>Dashboard</span>
                        </a>
                        <a class="nav-link @(currentController == "Doctors" ? "active" : string.Empty)" asp-controller="Doctors" asp-action="Index">
                            <i class="bi bi-heart-pulse"></i>
                            <span>Doctors</span>
                        </a>
                        <a class="nav-link @(currentController == "DoctorAvailabilities" ? "active" : string.Empty)" asp-controller="DoctorAvailabilities" asp-action="Index">
                            <i class="bi bi-calendar2-week"></i>
                            <span>Doctor Availability</span>
                        </a>
                        <a class="nav-link @(currentController == "Patients" ? "active" : string.Empty)" asp-controller="Patients" asp-action="Index">
                            <i class="bi bi-people"></i>
                            <span>Patients</span>
                        </a>
                        <a class="nav-link @(currentController == "Appointments" ? "active" : string.Empty)" asp-controller="Appointments" asp-action="Index">
                            <i class="bi bi-calendar-check"></i>
                            <span>Appointments</span>
                        </a>
                    }
                    else
                    {
                        <a class="nav-link @(currentController == "Profile" ? "active" : string.Empty)" asp-controller="Profile" asp-action="MyProfile">
                            <i class="bi bi-person-vcard"></i>
                            <span>My Profile</span>
                        </a>
                        <a class="nav-link @(currentController == "Appointments" && ViewContext.RouteData.Values["action"]?.ToString() == "Create" ? "active" : string.Empty)" asp-controller="Appointments" asp-action="Create">
                            <i class="bi bi-calendar-plus"></i>
                            <span>Book Appointment</span>
                        </a>
                        <a class="nav-link @(currentController == "Appointments" && ViewContext.RouteData.Values["action"]?.ToString() != "Create" ? "active" : string.Empty)" asp-controller="Appointments" asp-action="Index">
                            <i class="bi bi-calendar-check"></i>
                            <span>My Appointments</span>
                        </a>
                    }
                </nav>
                <div class="mt-auto pt-3 border-top" style="border-color: var(--app-border) !important;">
                    <div class="px-2">
                        <p class="text-muted small mb-2">Logged in as:</p>
                        <p class="text-muted small mb-0">@displayName</p>
                    </div>
                </div>
            </aside>
        }

        <div class="app-main">
            <!-- Top Bar -->
            <header class="app-topbar">
                <div class="d-flex align-items-center gap-3 flex-grow-1 min-w-0">
                    @if (isAuthenticated)
                    {
                        <button class="btn btn-icon d-lg-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#mobileSidebar" aria-controls="mobileSidebar">
                            <i class="bi bi-list"></i>
                        </button>
                    }
                    <div class="text-truncate">
                        <p class="app-title mb-0">@ViewData["Title"]</p>
                        @if (isAuthenticated)
                        {
                            <span class="app-subtitle">Professional clinic management</span>
                        }
                    </div>
                </div>
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <button id="themeToggle" type="button" class="btn btn-outline-secondary btn-sm" title="Toggle dark mode">
                        <i class="bi bi-moon-stars"></i>
                        <span class="d-none d-md-inline ms-1">Dark mode</span>
                    </button>
                    @if (isAuthenticated)
                    {
                        <div class="dropdown">
                            <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false" title="User menu">
                                <i class="bi bi-person-circle"></i>
                                <span class="d-none d-md-inline ms-1">@displayName.Split("@")[0]</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><span class="dropdown-header">@displayName</span></li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post" class="w-100">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item">
                                            <i class="bi bi-box-arrow-right me-2"></i>Logout
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a class="btn btn-outline-primary btn-sm" asp-controller="Account" asp-action="Login">
                            <i class="bi bi-box-arrow-in-right"></i>
                            <span class="d-none d-md-inline ms-1">Login</span>
                        </a>
                        <a class="btn btn-primary btn-sm" asp-controller="Account" asp-action="Register">
                            <i class="bi bi-person-plus"></i>
                            <span class="d-none d-md-inline ms-1">Register</span>
                        </a>
                    }
                </div>
            </header>

            <!-- Main Content -->
            <main class="app-content">
                @RenderBody()
            </main>

            <!-- Footer -->
            @if (isAuthenticated)
            {
                <footer class="mt-auto py-4 border-top" style="border-color: var(--app-border) !important; color: var(--app-muted);">
                    <div class="container-fluid px-4">
                        <div class="row g-4">
                            <div class="col-md-6">
                                <p class="small mb-1"><strong>Clinic Management System</strong></p>
                                <p class="small mb-0">&copy; 2026. Professional healthcare administration platform.</p>
                            </div>
                            <div class="col-md-6 text-md-end">
                                <p class="small mb-0">Last updated: @DateTime.Now.ToString("MMM dd, yyyy HH:mm")</p>
                            </div>
                        </div>
                    </div>
                </footer>
            }
        </div>
    </div>

    <!-- Toast Notifications Container -->
    <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1100;">
        @if (TempData["Success"] != null)
        {
            <div class="toast text-bg-success border-0 show" role="alert" aria-live="polite" aria-atomic="true" data-bs-delay="4000">
                <div class="toast-header">
                    <i class="bi bi-check-circle me-2"></i>
                    <strong class="me-auto">Success</strong>
                    <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
                <div class="toast-body">
                    @TempData["Success"]
                </div>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="toast text-bg-danger border-0 show" role="alert" aria-live="polite" aria-atomic="true" data-bs-delay="5000">
                <div class="toast-header">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    <strong class="me-auto">Error</strong>
                    <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
                <div class="toast-body">
                    @TempData["Error"]
                </div>
            </div>
        }
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
