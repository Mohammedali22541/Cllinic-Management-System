@model UpdateDoctorAvailabilityDto

@{
    ViewData["Title"] = "Update Availability";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Update Availability</h1>
        <p class="page-subtitle">Keep doctor working times and slot duration accurate.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i>
        Back to Availability
    </a>
</div>

<div class="card card-surface">
    <div class="card-body">
        <form asp-action="Update" asp-route-id="@Model.Id" method="post" class="row g-3">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="col-md-6">
                <div class="form-floating">
                    <select asp-for="DoctorId" class="form-select">
                        <option value="">Select a doctor</option>
                        @if (ViewBag.Doctors != null)
                        {
                            @foreach (var doctor in ViewBag.Doctors)
                            {
                                <option value="@doctor.Value">@doctor.Text</option>
                            }
                        }
                    </select>
                    <label asp-for="DoctorId">Doctor</label>
                </div>
                <span asp-validation-for="DoctorId" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <div class="form-floating">
                    <select asp-for="DayOfWeek" class="form-select">
                        @foreach (DayOfWeek day in Enum.GetValues(typeof(DayOfWeek)))
                        {
                            <option value="@day">@day</option>
                        }
                    </select>
                    <label asp-for="DayOfWeek">Day Of Week</label>
                </div>
                <span asp-validation-for="DayOfWeek" class="text-danger small"></span>
            </div>

            <div class="col-md-4">
                <div class="form-floating">
                    <input asp-for="StartTime" type="time" class="form-control" />
                    <label asp-for="StartTime">Start Time</label>
                </div>
                <span asp-validation-for="StartTime" class="text-danger small"></span>
            </div>

            <div class="col-md-4">
                <div class="form-floating">
                    <input asp-for="EndTime" type="time" class="form-control" />
                    <label asp-for="EndTime">End Time</label>
                </div>
                <span asp-validation-for="EndTime" class="text-danger small"></span>
            </div>

            <div class="col-md-4">
                <div class="form-floating">
                    <input asp-for="SlotDurationInMinutes" type="number" min="1" class="form-control" placeholder="30" />
                    <label asp-for="SlotDurationInMinutes">Slot Duration</label>
                </div>
                <span asp-validation-for="SlotDurationInMinutes" class="text-danger small"></span>
            </div>

            <div class="col-12 d-flex flex-wrap gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check2-circle"></i>
                    Update Availability
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
