@model IEnumerable<DoctorAvailabilityListDto>

@{
    ViewData["Title"] = "Doctor Availability";
    var hasRecords = Model?.Any() == true;
}

<div class="page-header">
    <div>
        <h1 class="page-title">Doctor Availability</h1>
        <p class="page-subtitle">Manage doctor working days and appointment slot settings.</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>
            Add Availability
        </a>
    </div>
</div>

<div class="card card-surface mb-4">
    <div class="card-body d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
        <div>
            <h5 class="mb-1">Working Schedule</h5>
            <p class="text-muted mb-0">Search and manage doctor availability records.</p>
        </div>
        <div class="flex-grow-1 flex-md-grow-0" style="min-width: 260px;">
            <div class="input-group">
                <span class="input-group-text bg-transparent">
                    <i class="bi bi-search"></i>
                </span>
                <input class="form-control" data-search-table="#availabilityTable" placeholder="Search availability..." />
            </div>
        </div>
    </div>
</div>

<div class="card card-surface">
    <div class="table-responsive">
        <table class="table table-hover table-striped align-middle mb-0" id="availabilityTable">
            <thead>
                <tr>
                    <th class="ps-4">Doctor Name</th>
                    <th>Day Of Week</th>
                    <th>Start Time</th>
                    <th>End Time</th>
                    <th>Slot Duration</th>
                    <th class="text-end pe-4">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (hasRecords)
                {
                    foreach (var availability in Model!)
                    {
                        <tr>
                            <td class="ps-4 fw-semibold">@availability.DoctorName</td>
                            <td>
                                <span class="badge rounded-pill badge-soft-primary">@availability.DayOfWeek</span>
                            </td>
                            <td>@availability.StartTime.ToString("HH:mm")</td>
                            <td>@availability.EndTime.ToString("HH:mm")</td>
                            <td>@availability.SlotDurationInMinutes minutes</td>
                            <td class="pe-4">
                                <div class="d-flex flex-wrap justify-content-end gap-2">
                                    <a asp-action="Update" asp-route-id="@availability.Id" class="btn btn-sm rounded-2 btn-outline-warning" title="Edit Availability">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@availability.Id" class="btn btn-sm rounded-2 btn-outline-danger" title="Delete Availability">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                <tr data-empty-row class="@(hasRecords ? "d-none" : string.Empty)">
                    <td colspan="6" class="empty-state">No availability records found. Add a working schedule to get started.</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
