@{
    ViewData["Title"] = "Access Denied";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Access Denied</h1>
        <p class="page-subtitle">You don't have permission to access this resource.</p>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card card-surface text-center">
            <div class="card-body py-5">
                <div class="display-4 text-danger mb-3">
                    <i class="bi bi-shield-exclamation"></i>
                </div>
                <h2 class="fw-bold mb-2">Access Denied</h2>
                <p class="text-muted mb-4">You do not have the required permissions to view this page. If you believe this is an error, please contact your administrator.</p>
                
                <div class="alert alert-info" role="alert">
                    <i class="bi bi-info-circle me-2"></i>
                    <strong>Current Role:</strong> @(User.IsInRole("Admin") ? "Administrator" : "Standard User")
                </div>

                <div class="d-flex gap-2 justify-content-center flex-wrap">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                        <i class="bi bi-house me-2"></i>Go to Home
                    </a>
                    <a href="javascript:history.back()" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-2"></i>Go Back
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

