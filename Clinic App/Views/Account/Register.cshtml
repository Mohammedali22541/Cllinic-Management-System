@model RegisterDto

@{
    ViewData["Title"] = "Create Account";
}

<div class="auth-split">
    <section class="auth-panel">
        <div class="auth-brand-mark">
            <i class="bi bi-heart-pulse"></i>
        </div>
        <p class="auth-eyebrow">Patient Portal</p>
        <h1>Start with an account, then complete your patient profile.</h1>
        <p class="auth-lead">After registration, you can add your profile, book appointments, and review upcoming visits.</p>
        <div class="auth-benefits">
            <div><i class="bi bi-person-plus"></i><span>Create a secure account</span></div>
            <div><i class="bi bi-clipboard2-pulse"></i><span>Save your patient details</span></div>
            <div><i class="bi bi-calendar-plus"></i><span>Book appointments with available doctors</span></div>
        </div>
    </section>

    <section class="auth-form-panel">
        <div class="auth-card auth-card-modern">
            <div class="auth-card-body">
                <div class="mb-4">
                    <p class="auth-eyebrow text-primary mb-2">Register</p>
                    <h2 class="fw-bold mb-2">Create your account</h2>
                    <p class="text-muted mb-0">Use these details to sign in to the clinic portal.</p>
                </div>

                <form asp-action="Register" method="post">
                    @Html.AntiForgeryToken()

                    @if (ViewData.ModelState.Values.Any(v => v.Errors.Count > 0))
                    {
                        <div class="alert alert-danger d-flex align-items-center mb-4" role="alert">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            <div asp-validation-summary="ModelOnly"></div>
                        </div>
                    }

                    <div class="form-floating mb-3">
                        <input asp-for="FullName" class="form-control auth-input" placeholder="Full name" />
                        <label asp-for="FullName"><i class="bi bi-person me-2"></i>Full Name</label>
                        <span asp-validation-for="FullName" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Email" class="form-control auth-input" placeholder="name@example.com" />
                        <label asp-for="Email"><i class="bi bi-envelope me-2"></i>Email Address</label>
                        <span asp-validation-for="Email" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Phone" class="form-control auth-input" placeholder="Phone number" />
                        <label asp-for="Phone"><i class="bi bi-telephone me-2"></i>Phone Number</label>
                        <span asp-validation-for="Phone" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Age" class="form-control auth-input" placeholder="Age" />
                        <label asp-for="Age"><i class="bi bi-person-badge me-2"></i>Age</label>
                        <span asp-validation-for="Age" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Password" type="password" class="form-control auth-input" placeholder="Password" />
                        <label asp-for="Password"><i class="bi bi-lock me-2"></i>Password</label>
                        <span asp-validation-for="Password" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="form-floating mb-4">
                        <input asp-for="ConfirmPassword" type="password" class="form-control auth-input" placeholder="Confirm password" />
                        <label asp-for="ConfirmPassword"><i class="bi bi-lock-check me-2"></i>Confirm Password</label>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small d-block mt-1"></span>
                    </div>

                    <button type="submit" class="btn btn-primary btn-auth btn-lg w-100">
                        <i class="bi bi-person-plus me-2"></i>Create Account
                    </button>

                    <p class="text-center text-muted small mb-0 mt-4">
                        Already registered?
                        <a asp-action="Login" class="fw-semibold">Sign in</a>
                    </p>
                </form>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
