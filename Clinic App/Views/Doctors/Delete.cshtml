@model DoctorDetailsDto

@{
    ViewData["Title"] = "Delete Doctor";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Delete Doctor</h1>
        <p class="page-subtitle">This action will remove the doctor from the active roster.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i>
        Back to Doctors
    </a>
</div>

<div class="card card-surface border border-danger">
    <div class="card-body">
        <div class="d-flex flex-column flex-lg-row gap-4 align-items-lg-center">
            <div class="flex-grow-1">
                <h4 class="fw-semibold text-danger mb-2">Confirm deletion</h4>
                <p class="text-muted mb-3">You're about to remove <strong>@Model.Name</strong>. This cannot be undone.</p>
                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="p-3 border rounded-3 h-100">
                            <div class="text-muted small">Phone</div>
                            <div class="fw-semibold">@Model.Phone</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="p-3 border rounded-3 h-100">
                            <div class="text-muted small">Specialization</div>
                            <div class="fw-semibold">@Model.Specialization</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="p-3 border rounded-3 h-100">
                            <div class="text-muted small">Appointments</div>
                            <div class="fw-semibold">@Model.AppointmentsCount</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="text-lg-end">
                <form asp-action="DeleteConfirmed" asp-route-id="@Model.Id" method="post"
                      data-confirm
                      data-confirm-title="Delete doctor?"
                      data-confirm-text="This doctor will be removed from the active roster."
                      data-confirm-button="Yes, delete it">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger w-100 mb-2">
                        <i class="bi bi-trash me-1"></i>
                        Delete Doctor
                    </button>
                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary w-100">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>
