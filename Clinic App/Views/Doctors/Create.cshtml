@model CreateDoctorDto

@{
    ViewData["Title"] = "Add Doctor";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Add Doctor</h1>
        <p class="page-subtitle">Create a new specialist profile for the clinic.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i>
        Back to Doctors
    </a>
</div>

<div class="card card-surface">
    <div class="card-body">
        <form asp-action="Create" method="post" class="row g-3">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="col-md-6">
                <div class="form-floating">
                    <input asp-for="Name" class="form-control" placeholder="Dr. Jane Doe" />
                    <label asp-for="Name"></label>
                </div>
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <div class="form-floating">
                    <input asp-for="Phone" class="form-control" placeholder="(000) 000-0000" />
                    <label asp-for="Phone"></label>
                </div>
                <span asp-validation-for="Phone" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <div class="form-floating">
                    <select asp-for="Specialization" class="form-select">
                        <option value="">Select specialization</option>
                        @foreach (Specialization specialization in Enum.GetValues(typeof(Specialization)))
                        {
                            <option value="@specialization">@specialization</option>
                        }
                    </select>
                    <label asp-for="Specialization"></label>
                </div>
                <span asp-validation-for="Specialization" class="text-danger small"></span>
            </div>

            <div class="col-12 d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check2-circle"></i>
                    Save Doctor
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
