@model DoctorDetailsDto

@{
    ViewData["Title"] = "Doctor Details";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Doctor Profile</h1>
        <p class="page-subtitle">Review specialist information and engagement.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i>
        Back to Doctors
    </a>
</div>

<div class="card card-surface">
    <div class="card-body">
        <div class="row g-4">
            <div class="col-lg-8">
                <h4 class="fw-semibold mb-3">@Model.Name</h4>
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="p-3 border rounded-3 h-100">
                            <div class="text-muted small">Phone</div>
                            <div class="fw-semibold">@Model.Phone</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-3 border rounded-3 h-100">
                            <div class="text-muted small">Specialization</div>
                            <div class="fw-semibold">@Model.Specialization</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="p-4 border rounded-3 h-100 d-flex flex-column justify-content-between">
                    <div>
                        <div class="text-muted small">Appointments</div>
                        <div class="display-6 fw-semibold">@Model.AppointmentsCount</div>
                        <p class="text-muted">Scheduled with this doctor.</p>
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        <a asp-action="Update" asp-route-id="@Model.Id" class="btn btn-outline-primary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">Delete</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
