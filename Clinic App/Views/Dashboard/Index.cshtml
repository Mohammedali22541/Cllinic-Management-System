@model AdminDashboardDto

@{
    ViewData["Title"] = "Dashboard";
    var today = DateTime.Now;
}

<div class="page-header mb-5">
    <div>
        <h1 class="page-title">Welcome Back, Admin</h1>
        <p class="page-subtitle">@today.ToString("dddd, MMMM d, yyyy")</p>
    </div>
</div>

<!-- Dashboard Stats Grid -->
<div class="row g-4 mb-5">
    <!-- Doctors Card -->
    <div class="col-md-6 col-lg-3">
        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted small mb-2">Healthcare Providers</p>
                    <h3 class="display-6 fw-bold mb-2">@Model.DoctorsCount</h3>
                    <p class="text-muted small">Active doctors in the clinic</p>
                </div>
                <div class="stat-icon" style="background: rgba(37, 99, 235, 0.1); color: #2563eb; padding: 0.75rem; border-radius: 0.75rem; font-size: 1.5rem;">
                    <i class="bi bi-heart-pulse"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Patients Card -->
    <div class="col-md-6 col-lg-3">
        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted small mb-2">Registered Patients</p>
                    <h3 class="display-6 fw-bold mb-2">@Model.PatientsCount</h3>
                    <p class="text-muted small">Total patients in system</p>
                </div>
                <div class="stat-icon" style="background: rgba(34, 197, 94, 0.1); color: #22c55e; padding: 0.75rem; border-radius: 0.75rem; font-size: 1.5rem;">
                    <i class="bi bi-people"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Total Appointments Card -->
    <div class="col-md-6 col-lg-3">
        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted small mb-2">Total Appointments</p>
                    <h3 class="display-6 fw-bold mb-2">@Model.AppointmentsCount</h3>
                    <p class="text-muted small">All scheduled appointments</p>
                </div>
                <div class="stat-icon" style="background: rgba(59, 130, 246, 0.1); color: #3b82f6; padding: 0.75rem; border-radius: 0.75rem; font-size: 1.5rem;">
                    <i class="bi bi-calendar-check"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Pending Appointments Card -->
    <div class="col-md-6 col-lg-3">
        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted small mb-2">Pending Appointments</p>
                    <h3 class="display-6 fw-bold mb-2">@Model.PendingAppointmentsCount</h3>
                    <p class="text-muted small">Awaiting confirmation</p>
                </div>
                <div class="stat-icon" style="background: rgba(245, 158, 11, 0.1); color: #f59e0b; padding: 0.75rem; border-radius: 0.75rem; font-size: 1.5rem;">
                    <i class="bi bi-clock-history"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions Section -->
<div class="row g-4">
    <div class="col-lg-8">
        <div class="card card-surface">
            <div class="card-body">
                <h5 class="card-title mb-4">Quick Actions</h5>
                <div class="row g-3">
                    <div class="col-md-6">
                        <a href="@Url.Action("Index", "Doctors")" class="btn btn-outline-primary w-100 py-3 text-start">
                            <i class="bi bi-heart-pulse me-2"></i>
                            <div>
                                <strong>Manage Doctors</strong>
                                <br>
                                <small class="text-muted">Add, edit, or remove healthcare providers</small>
                            </div>
                        </a>
                    </div>
                    <div class="col-md-6">
                        <a href="@Url.Action("Index", "Patients")" class="btn btn-outline-primary w-100 py-3 text-start">
                            <i class="bi bi-people me-2"></i>
                            <div>
                                <strong>Manage Patients</strong>
                                <br>
                                <small class="text-muted">View and manage patient records</small>
                            </div>
                        </a>
                    </div>
                    <div class="col-md-6">
                        <a href="@Url.Action("Index", "Appointments")" class="btn btn-outline-primary w-100 py-3 text-start">
                            <i class="bi bi-calendar-check me-2"></i>
                            <div>
                                <strong>Manage Appointments</strong>
                                <br>
                                <small class="text-muted">View and update appointment schedules</small>
                            </div>
                        </a>
                    </div>
                    <div class="col-md-6">
                        <a href="@Url.Action("Create", "Appointments")" class="btn btn-outline-primary w-100 py-3 text-start">
                            <i class="bi bi-plus-lg me-2"></i>
                            <div>
                                <strong>Add Appointment</strong>
                                <br>
                                <small class="text-muted">Schedule a new appointment</small>
                            </div>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- System Status Card -->
    <div class="col-lg-4">
        <div class="card card-surface">
            <div class="card-body">
                <h5 class="card-title mb-4">System Status</h5>
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="small">System Health</span>
                        <span class="badge badge-soft-success">Excellent</span>
                    </div>
                    <div class="progress" style="height: 6px;">
                        <div class="progress-bar" role="progressbar" style="width: 100%;" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                </div>
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="small">Database</span>
                        <span class="badge badge-soft-success">Connected</span>
                    </div>
                    <div class="progress" style="height: 6px;">
                        <div class="progress-bar" role="progressbar" style="width: 100%;" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                </div>
                <hr>
                <div class="text-center">
                    <p class="text-muted small mb-0">Last updated: @DateTime.Now.ToString("hh:mm tt")</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Additional Info Section -->
<div class="mt-5 p-4 border rounded-3" style="background: var(--app-surface-alt);">
    <div class="d-flex align-items-start gap-3">
        <div style="color: var(--app-primary); font-size: 1.5rem;">
            <i class="bi bi-info-circle"></i>
        </div>
        <div>
            <h6 class="fw-semibold">Welcome to the Clinic Management System</h6>
            <p class="text-muted small mb-0">This comprehensive dashboard provides you with real-time insights into clinic operations. Manage your doctors, patients, and appointments efficiently. For assistance, please contact the system administrator.</p>
        </div>
    </div>
</div>
