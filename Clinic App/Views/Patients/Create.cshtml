@model CreatePatientDto

@{
    ViewData["Title"] = "Add Patient";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Add Patient</h1>
        <p class="page-subtitle">Register a new patient in the clinic system.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i>
        Back to Patients
    </a>
</div>

<div class="card card-surface">
    <div class="card-body">
        <form asp-action="Create" method="post" class="row g-3">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="col-md-6">
                <div class="form-floating">
                    <input asp-for="Name" class="form-control" placeholder="John Doe" />
                    <label asp-for="Name">Patient Name</label>
                </div>
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <div class="form-floating">
                    <input asp-for="Age" type="number" class="form-control" placeholder="30" />
                    <label asp-for="Age">Age</label>
                </div>
                <span asp-validation-for="Age" class="text-danger small"></span>
            </div>

            <div class="col-12">
                <div class="form-floating">
                    <input asp-for="Phone" class="form-control" placeholder="(000) 000-0000" />
                    <label asp-for="Phone">Phone Number</label>
                </div>
                <span asp-validation-for="Phone" class="text-danger small"></span>
            </div>

            <div class="col-12 d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check2-circle"></i>
                    Save Patient
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
