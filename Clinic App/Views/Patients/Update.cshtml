@model UpdatePatientDto

@{
    ViewData["Title"] = "Update Patient";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Update Patient</h1>
        <p class="page-subtitle">Keep patient information accurate and current.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i>
        Back to Patients
    </a>
</div>

<div class="card card-surface">
    <div class="card-body">
        <form asp-action="Update" asp-route-id="@Model.Id" method="post" class="row g-3">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="col-md-6">
                <div class="form-floating">
                    <input asp-for="Name" class="form-control" placeholder="Patient name" />
                    <label asp-for="Name">Patient Name</label>
                </div>
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <div class="form-floating">
                    <input asp-for="Age" type="number" class="form-control" placeholder="Age" />
                    <label asp-for="Age">Age</label>
                </div>
                <span asp-validation-for="Age" class="text-danger small"></span>
            </div>

            <div class="col-12">
                <div class="form-floating">
                    <input asp-for="Phone" class="form-control" placeholder="Phone" />
                    <label asp-for="Phone">Phone Number</label>
                </div>
                <span asp-validation-for="Phone" class="text-danger small"></span>
            </div>

            <div class="col-12 d-flex flex-wrap gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check2-circle"></i>
                    Update Patient
                </button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">View Details</a>
                <a asp-action="Index" class="btn btn-light">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
