@model AppointmentDetailsDto

@{
    ViewData["Title"] = "Delete Appointment";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Delete Appointment</h1>
        <p class="page-subtitle">Are you sure you want to delete this appointment?</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i>
        Back to Appointments
    </a>
</div>

<div class="card card-surface">
    <div class="card-body">
        <div class="alert alert-warning" role="alert">
            <i class="bi bi-exclamation-triangle"></i>
            <strong>Warning!</strong> This action cannot be undone.
        </div>

        <div class="row mb-4">
            <div class="col-md-6 mb-3">
                <label class="form-label text-muted small">Date</label>
                <p class="form-control-plaintext fw-semibold">@Model.AppointmentDate.ToString("MMMM dd, yyyy HH:mm")</p>
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label text-muted small">Patient</label>
                <p class="form-control-plaintext fw-semibold">@Model.PatientName</p>
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label text-muted small">Doctor</label>
                <p class="form-control-plaintext fw-semibold">@Model.DoctorName</p>
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label text-muted small">Status</label>
                <p class="form-control-plaintext"><span class="badge rounded-pill badge-soft-primary">@Model.Status.ToString()</span></p>
            </div>
        </div>

        <form asp-action="DeleteConfirmed" asp-route-id="@Model.Id" method="post" class="d-flex gap-2"
              data-confirm
              data-confirm-title="Delete appointment?"
              data-confirm-text="This appointment will be removed from active records."
              data-confirm-button="Yes, delete it">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger">
                <i class="bi bi-trash"></i>
                Delete Appointment
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>
