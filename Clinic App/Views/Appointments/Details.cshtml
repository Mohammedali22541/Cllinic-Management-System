@model AppointmentDetailsDto

@{
    ViewData["Title"] = "Appointment Details";
    var isAdmin = User.IsInRole("Admin");
    var canCancel = Model.Status == ClinicApp.Data.Entites.Enums.AppointmentStatus.Pending;
}

<div class="page-header">
    <div>
        <h1 class="page-title">Appointment Details</h1>
        <p class="page-subtitle">View complete appointment information.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i>
        Back to Appointments
    </a>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card card-surface mb-4">
            <div class="card-body">
                <h5 class="card-title mb-4">Appointment Information</h5>
                
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label text-muted small">Date</label>
                        <p class="form-control-plaintext fw-semibold">@Model.AppointmentDate.ToString("MMMM dd, yyyy HH:mm")</p>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label text-muted small">Status</label>
                        <p class="form-control-plaintext">
                            <span class="badge rounded-pill badge-soft-primary">@Model.Status.ToString()</span>
                        </p>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label text-muted small">Patient</label>
                        <p class="form-control-plaintext fw-semibold">@Model.PatientName</p>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label text-muted small">Doctor</label>
                        <p class="form-control-plaintext fw-semibold">@Model.DoctorName</p>
                    </div>
                    <div class="col-12 mb-3">
                        <label class="form-label text-muted small">Symptoms or Notes</label>
                        <p class="form-control-plaintext fw-semibold">@(string.IsNullOrWhiteSpace(Model.Notes) ? "No notes provided." : Model.Notes)</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (isAdmin)
    {
        <div class="col-lg-4">
            <div class="card card-surface">
                <div class="card-body">
                    <h5 class="card-title mb-3">Admin Actions</h5>
                    @if (Model.Status == ClinicApp.Data.Entites.Enums.AppointmentStatus.Pending)
                    {
                        <div class="d-grid gap-2">
                            <form asp-action="UpdateStatus" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="appointmentId" value="@Model.Id" />
                                <input type="hidden" name="status" value="@ClinicApp.Data.Entites.Enums.AppointmentStatus.Completed" />
                                <button type="submit" class="btn btn-outline-primary text-start w-100">
                                    <i class="bi bi-check2-all me-2"></i>Mark Completed
                                </button>
                            </form>
                            <form asp-action="UpdateStatus" method="post"
                                  data-confirm
                                  data-confirm-title="Cancel appointment?"
                                  data-confirm-text="This appointment will be marked as cancelled."
                                  data-confirm-button="Yes, cancel it">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="appointmentId" value="@Model.Id" />
                                <input type="hidden" name="status" value="@ClinicApp.Data.Entites.Enums.AppointmentStatus.Cancelled" />
                                <button type="submit" class="btn btn-outline-danger text-start w-100">
                                    <i class="bi bi-x-circle me-2"></i>Cancel
                                </button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted small mb-2">No further status changes are available.</p>
                        <span class="badge rounded-pill badge-soft-primary">@Model.Status.ToString()</span>
                    }
                </div>
            </div>
        </div>
    }
    else if (canCancel)
    {
        <div class="col-lg-4">
            <div class="card card-surface">
                <div class="card-body">
                    <h5 class="card-title mb-3">Appointment Actions</h5>
                    <form asp-action="Cancel" asp-route-id="@Model.Id" method="post"
                          data-confirm
                          data-confirm-title="Cancel appointment?"
                          data-confirm-text="This appointment will be cancelled."
                          data-confirm-button="Yes, cancel it">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger w-100">
                            <i class="bi bi-x-circle me-2"></i>Cancel Appointment
                        </button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>

<div class="mt-4 d-flex gap-2">
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
    @if (isAdmin)
    {
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">
            <i class="bi bi-trash"></i>
            Delete
        </a>
    }
    else if (canCancel)
    {
        <form asp-action="Cancel" asp-route-id="@Model.Id" method="post"
              data-confirm
              data-confirm-title="Cancel appointment?"
              data-confirm-text="This appointment will be cancelled."
              data-confirm-button="Yes, cancel it">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-danger">
                <i class="bi bi-x-circle"></i>
                Cancel Appointment
            </button>
        </form>
    }
</div>
