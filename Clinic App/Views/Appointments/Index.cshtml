@model IEnumerable<GetAllAppointmentListDto>

@{
    var hasRecords = Model?.Any() == true;
    var isAdmin = User.IsInRole("Admin");
    ViewData["Title"] = isAdmin ? "Appointments" : "My Appointments";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Appointments</h1>
        <p class="page-subtitle">@(isAdmin ? "Manage all clinic appointments and schedules." : "View and manage your appointments.")</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>
            Book Appointment
        </a>
    </div>
</div>

<div class="card card-surface mb-4">
    <div class="card-body d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
        <div>
            <h5 class="mb-1">Appointment Schedule</h5>
            <p class="text-muted mb-0">View and manage appointment records.</p>
        </div>
        <div class="flex-grow-1 flex-md-grow-0" style="min-width: 260px;">
            <div class="input-group">
                <span class="input-group-text bg-transparent">
                    <i class="bi bi-search"></i>
                </span>
                <input class="form-control" data-search-table="#appointmentsTable" placeholder="Search appointments..." />
            </div>
        </div>
    </div>
</div>

<div class="card card-surface">
    <div class="table-responsive">
        <table class="table table-hover table-striped align-middle mb-0" id="appointmentsTable">
            <thead>
                <tr>
                    <th class="ps-4">Date</th>
                    @if (isAdmin)
                    {
                        <th>Patient</th>
                        <th>Doctor</th>
                    }
                    <th>Status</th>
                    <th class="text-end pe-4">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (hasRecords)
                {
                    foreach (var appointment in Model!)
                    {
                        var statusBadgeClass = appointment.Status switch
                        {
                            ClinicApp.Data.Entites.Enums.AppointmentStatus.Pending => "badge-soft-warning",
                            ClinicApp.Data.Entites.Enums.AppointmentStatus.Completed => "badge-soft-primary",
                            ClinicApp.Data.Entites.Enums.AppointmentStatus.Cancelled => "badge-soft-danger",
                            _ => "badge-soft-secondary"
                        };
                        <tr>
                            <td class="ps-4 fw-semibold">@appointment.AppointmentDate.ToString("MMM dd, yyyy")</td>
                            @if (isAdmin)
                            {
                                <td>@appointment.PatientName</td>
                                <td>@appointment.DoctorName</td>
                            }
                            <td>
                                <span class="badge rounded-pill @statusBadgeClass">@appointment.Status.ToString()</span>
                            </td>
                            <td class="pe-4">
                                <div class="d-flex flex-wrap justify-content-end gap-2">
                                    <a asp-action="Details" asp-route-id="@appointment.Id" class="btn btn-sm rounded-2 btn-outline-primary" title="View Details">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    @if (isAdmin)
                                    {
                                        <a asp-action="Delete" asp-route-id="@appointment.Id" class="btn btn-sm rounded-2 btn-outline-danger" title="Delete Appointment">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    }
                                    else if (appointment.Status == ClinicApp.Data.Entites.Enums.AppointmentStatus.Pending)
                                    {
                                        <form asp-action="Cancel" asp-route-id="@appointment.Id" method="post" class="d-inline"
                                              data-confirm
                                              data-confirm-title="Cancel appointment?"
                                              data-confirm-text="This appointment will be cancelled."
                                              data-confirm-button="Yes, cancel it">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm rounded-2 btn-outline-danger" title="Cancel Appointment">
                                                <i class="bi bi-x-circle"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                <tr data-empty-row class="@(hasRecords ? "d-none" : string.Empty)">
                    <td colspan="@(isAdmin ? "5" : "3")" class="empty-state">No appointments found. Book an appointment to get started.</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
